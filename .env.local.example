# Copy to .env.local. Devnet only. NEVER put secrets or private keys here.
# All values below are PUBLIC program IDs / public RPC endpoints — safe to commit
# as an example, but .env.local itself is gitignored.

# Solana RPC endpoint (devnet). A dedicated provider (Helius/Triton/QuickNode)
# is recommended over the public endpoint to avoid airdrop/rate limits.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Server-side RPC for the /api/swig/* helper routes. The helper runs against
# MAINNET — use a dedicated provider (Helius/Triton/QuickNode) mainnet endpoint.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Shared bearer the Avici app/backend must send as `Authorization: Bearer <token>`
# to call the /api/swig/* helper routes. Generate a strong random value, e.g.
#   node -e 'console.log("avici_sk_"+require("crypto").randomBytes(24).toString("hex"))'
SESSION_HELPER_BEARER=replace-with-a-strong-random-token

# Swig program — fixed ID, same on devnet & mainnet (verified executable on devnet)
NEXT_PUBLIC_SWIG_PROGRAM_ID=swigypWHEksbC64pWKwah1WTeh9JXwx8H1rJHLdbQMB

# MagicBlock / Gum session-keys program (verified executable on devnet)
NEXT_PUBLIC_GUM_SESSION_PROGRAM_ID=KeyspM2ssCJbqUhQ4k7sveSiY4WjnYsrXkC8oDbwde5

# A target program the Gum session token is scoped to (lifecycle demo only).
# Defaults to the Gum session program itself; any executable program ID works
# since the lifecycle demo only stores (not validates) the target at create time.
NEXT_PUBLIC_GUM_TARGET_PROGRAM_ID=KeyspM2ssCJbqUhQ4k7sveSiY4WjnYsrXkC8oDbwde5
